prefix_rule(pattern=["curl", "-s", "-o", "/tmp/zellij_flake.nix", "-w", "%{http_code}\\n", "https://raw.githubusercontent.com/zellij-org/zellij/main/flake.nix"], decision="allow")
prefix_rule(pattern=["curl", "-Ls", "https://raw.githubusercontent.com/NixOS/nixpkgs/nixos-unstable/pkgs/by-name/ze/zellij/package.nix"], decision="allow")
