prefix_rule(pattern=["curl", "-L", "--max-time", "60", "https://arxiv.org/pdf/2601.15621.pdf", "-o", "/tmp/tts_sources/qwen3_tts_tech_report_2601.15621.pdf"], decision="allow")
prefix_rule(pattern=["curl", "-L", "--max-time", "60", "https://ar5iv.labs.arxiv.org/html/2601.15621", "-o", "/tmp/tts_sources/ar5iv_2601.15621.html"], decision="allow")
prefix_rule(pattern=["python3", "-m", "pip", "install"], decision="allow")
prefix_rule(pattern=["curl", "-s", "https://api.github.com/search/code?q=%22github:zellij-org/zellij%22+filename:flake.nix"], decision="allow")
