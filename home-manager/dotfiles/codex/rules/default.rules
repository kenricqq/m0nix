prefix_rule(pattern=["curl", "-Ls", "https://sourcegraph.com/search?q=context:global+zellij-org/zellij+file:flake.nix&patternType=standard"], decision="allow")
prefix_rule(pattern=["curl", "-s", "https://sourcegraph.com/search/stream?q=context:global+zellij-org/zellij+file:flake.nix&v=V3"], decision="allow")
