# theme = Nightfox
theme = Kanagawa Dragon

# background = 282c34
# foreground = ffffff

# background-image = "~/Images/deer.png"
# background-image-opacity = 0.5
# background-image-position = center
# background-image-fit = contain

# custom-shader = shaders/starfield-colors.glsl
custom-shader = shaders/cursor_blaze.glsl

shell-integration = zsh
shell-integration-features = true

# env = SHELL=/bin/fish
# initial-command = "/etc/profiles/per-user/$USER/bin/fish -lc 'exec zellij attach -c home'"
 # command = "/etc/profiles/per-user/$USER/bin/fish -lc 'exec zesh cn $(zesh l | fzf)'"
initial-command = "/etc/profiles/per-user/$USER/bin/fish -il"
# command = "/etc/profiles/per-user/$USER/bin/fish -il"

# contain (def), cover, stretch, none
background-image-fit = cover
background-opacity = 0.97
background-blur = true
unfocused-split-opacity = 0.7
# unfocused-split-fill = #000000
split-divider-color = #F0F00F

# cursor
cursor-style-blink = false
mouse-hide-while-typing = true

macos-titlebar-style = hidden
# macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-titlebar-proxy-icon = hidden
# official (default), blueprint, chalkboard, microchip, glass, holographic, paper, retro, xray
macos-icon = chalkboard
# aluminum (default), beige, plastic, chrome
# macos-icon-frame = beige

# start window in maximized state
# maximize = true

window-padding-x = 20
window-padding-y = 20,0
window-padding-color = extend

window-inherit-working-directory = true
window-save-state = always

# Empty values reset the configuration to the default value
font-family = "0xProto Nerd Font Mono"
# font-family = "SpaceMono Nerd Font Mono"
## Krypton (Mech sans)/Radon (Handwriting)/Xenon (serif)/Argon (sans 1)/Neon (sans 2)
# font-family = "Monaspace Neon"
# font-family = "IosevkaTerm NFM"
# font-family = "Source Code Pro"
# font-family = "JetBrainsMono Nerd Font Mono"
font-size = 15

adjust-cell-height = 15%
minimum-contrast = 3

quick-terminal-position = center
quick-terminal-size = 50%,500px
quick-terminal-animation-duration = 0

right-click-action = copy-or-paste
copy-on-select = clipboard
confirm-close-surface = false
# disable to have dropdown term
quit-after-last-window-closed = false

# keybind = global:cmd+shift+grave_accent=toggle_quick_terminal
keybind = global:alt+enter=toggle_quick_terminal
keybind = cmd+\=new_split:right
keybind = cmd+shift+\=new_split:down

keybind = cmd+shift+f=write_scrollback_file:open

# keyboard scroll
keybind = ctrl+shift+k=scroll_page_lines:-30
keybind = ctrl+shift+j=scroll_page_lines:30
# keybind = ctrl+shift+d=scroll_page_down
# keybind = ctrl+shift+u=scroll_page_up

# goto split
keybind = cmd+shift+h=goto_split:left
keybind = cmd+shift+l=goto_split:right
keybind = cmd+shift+j=goto_split:bottom
keybind = cmd+shift+k=goto_split:top

# resize split
keybind = cmd+ctrl+h=resize_split:left,30
keybind = cmd+ctrl+l=resize_split:right,30
keybind = cmd+ctrl+k=resize_split:up,30
keybind = cmd+ctrl+j=resize_split:down,30

keybind = cmd+ctrl+r=equalize_splits
keybind = cmd+shift+f=toggle_window_float_on_top

keybind = ctrl+l=clear_screen

