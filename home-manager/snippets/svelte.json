{
  "svelte: $state (rune)": {
    "prefix": "s-state",
    "body": ["let ${1:name} = $state(${2:0});"],
    "description": "Svelte 5 rune: reactive state"
  },
  "svelte: $state() (no initial)": {
    "prefix": "s-state-empty",
    "body": ["let ${1:name} = $state();"],
    "description": "Svelte 5 rune: reactive state without an initial value (often for refs set later)"
  },
  "svelte: $state.raw": {
    "prefix": "s-state-raw",
    "body": ["let ${1:name} = $state.raw(${2:[]});"],
    "description": "Svelte 5 rune: non-deeply-reactive state (reassign instead of mutate)"
  },
  "svelte: $state.snapshot": {
    "prefix": "s-state-snapshot",
    "body": ["$state.snapshot(${1:state})"],
    "description": "Svelte 5: take a non-proxy snapshot of a $state value"
  },
  "svelte: $state.eager": {
    "prefix": "s-state-eager",
    "body": ["$state.eager(${1:value})"],
    "description": "Svelte 5: force eager UI update for state used by await expressions"
  },

  "svelte: $derived (rune)": {
    "prefix": "s-derived",
    "body": ["let ${1:name} = $derived(${2:expression});"],
    "description": "Svelte 5 rune: derived (computed) state"
  },
  "svelte: $derived.by": {
    "prefix": "s-derived-by",
    "body": [
      "let ${1:name} = $derived.by(() => {",
      "\t${2:// compute and return a value}",
      "});"
    ],
    "description": "Svelte 5 rune: derived state using a function body"
  },

  "svelte: $effect": {
    "prefix": "s-effect",
    "body": [
      "$effect(() => {",
      "\t${1:// side effect (runs after DOM updates)}",
      "});"
    ],
    "description": "Svelte 5 rune: effect"
  },
  "svelte: $effect (with cleanup)": {
    "prefix": "s-effect-cleanup",
    "body": [
      "$effect(() => {",
      "\t${1:// setup}",
      "\treturn () => {",
      "\t\t${2:// cleanup}",
      "\t};",
      "});"
    ],
    "description": "Svelte 5 rune: effect with teardown"
  },
  "svelte: $effect.pre": {
    "prefix": "s-effect-pre",
    "body": [
      "$effect.pre(() => {",
      "\t${1:// runs before DOM updates}",
      "});"
    ],
    "description": "Svelte 5 rune: pre-effect (runs before DOM updates)"
  },
  "svelte: $effect.root": {
    "prefix": "s-effect-root",
    "body": [
      "const ${1:cleanup} = $effect.root(() => {",
      "\t$effect(() => {",
      "\t\t${2:// nested tracked effects here}",
      "\t});",
      "",
      "\treturn () => {",
      "\t\t${3:// root cleanup (manual control)}",
      "\t};",
      "});"
    ],
    "description": "Svelte 5: advanced $effect.root (returns a cleanup function)"
  },
  "svelte: $effect.tracking()": {
    "prefix": "s-effect-tracking",
    "body": ["$effect.tracking()"],
    "description": "Svelte 5: whether code is running in a tracking context"
  },
  "svelte: $effect.pending()": {
    "prefix": "s-effect-pending",
    "body": ["$effect.pending()"],
    "description": "Svelte 5: number of pending promises in the current await boundary"
  },

  "svelte: $props (basic)": {
    "prefix": "s-props",
    "body": ["let { ${1:prop} } = $props();"],
    "description": "Svelte 5 rune: declare props via destructuring"
  },
  "svelte: $props (rest)": {
    "prefix": "s-props-rest",
    "body": ["let { ${1:prop}, ...${2:rest} } = $props();"],
    "description": "Svelte 5: destructure props + capture rest props"
  },
  "svelte: $props (typed interface)": {
    "prefix": "s-props-ts",
    "body": [
      "interface Props {",
      "\t${1:prop}: ${2:string};",
      "}",
      "",
      "let { ${1:prop} }: Props = $props();"
    ],
    "description": "Svelte 5: typed props (TypeScript)"
  },
  "svelte: $props.id()": {
    "prefix": "s-props-id",
    "body": ["const ${1:uid} = $props.id();"],
    "description": "Svelte 5: unique per-component-instance id"
  },

  "svelte: $bindable prop": {
    "prefix": "s-bindable",
    "body": ["let { ${1:prop} = $bindable(), ...${2:props} } = $props();"],
    "description": "Svelte 5: mark a prop as bindable (enables bind:propName from parent)"
  },
  "svelte: bindable <input> wrapper pattern": {
    "prefix": "s-bindable-input",
    "body": [
      "<script lang=\"ts\">",
      "\tlet { value = $bindable(), ...props } = $props();",
      "</script>",
      "",
      "<input bind:value={value} {...props} />"
    ],
    "description": "Svelte 5: common bindable input wrapper"
  },

  "svelte: $inspect(...)": {
    "prefix": "s-inspect",
    "body": ["$inspect(${1:value});"],
    "description": "Svelte 5: dev-only reactive logging ($inspect)"
  },
  "svelte: $inspect(...).with": {
    "prefix": "s-inspect-with",
    "body": [
      "$inspect(${1:value}).with((type, value) => {",
      "\t${2:// type is 'init' | 'update'}",
      "});"
    ],
    "description": "Svelte 5: custom handler for $inspect output"
  },
  "svelte: $inspect.trace()": {
    "prefix": "s-inspect-trace",
    "body": [
      "$inspect.trace(${1:'label'});",
      "${2:// must be first statement in function body}"
    ],
    "description": "Svelte 5: trace reactive triggers inside derived/effect (dev)"
  },

  "svelte: {#snippet ...}{/snippet}": {
    "prefix": "s-snippet",
    "body": [
      "{#snippet ${1:name}(${2})}",
      "\t${3:<!-- snippet markup -->}",
      "{/snippet}"
    ],
    "description": "Svelte 5: declare a snippet"
  },
  "svelte: {@render ...}": {
    "prefix": "s-render-tag",
    "body": ["{@render ${1:snippet}(${2})}"],
    "description": "Svelte 5: render a snippet (render tag)"
  },
  "svelte: children snippet prop (slot replacement)": {
    "prefix": "s-children",
    "body": [
      "<script lang=\"ts\">",
      "\timport type { Snippet } from 'svelte';",
      "\tlet { children }: { children?: Snippet } = $props();",
      "</script>",
      "",
      "{#if children}",
      "\t{@render children()}",
      "{:else}",
      "\t${1:<!-- fallback -->}",
      "{/if}"
    ],
    "description": "Svelte 5: children snippet prop pattern (+ fallback)"
  },
  "svelte: type Snippet props (generic example)": {
    "prefix": "s-snippet-typing",
    "body": [
      "<script lang=\"ts\" generics=\"T\">",
      "\timport type { Snippet } from 'svelte';",
      "\tlet { data, row, children }: {",
      "\t\tdata: T[];",
      "\t\trow: Snippet<[T]>;",
      "\t\tchildren?: Snippet;",
      "\t} = $props();",
      "</script>"
    ],
    "description": "Svelte 5: typing snippet props (with generics)"
  },

  "svelte: event handler prop (onclick, oninput, ...)": {
    "prefix": "s-onprop",
    "body": [
      "${1|onclick,oninput,onchange,onsubmit,onkeydown,onkeyup,onpointerdown,onpointerup|}={${2:handler}}"
    ],
    "description": "Svelte 5: element event handlers are plain props (no on:)"
  },
  "svelte: inline event handler prop": {
    "prefix": "s-onprop-inline",
    "body": ["${1:onclick}={() => ${2}}"],
    "description": "Svelte 5: inline handler (no quotes)"
  },

  "svelte: <script module>": {
    "prefix": "s-module",
    "body": ["<script module>", "\t${1:// module script}", "</script>"],
    "description": "Svelte 5: module script (replaces context=\"module\")"
  },

  "svelte: {@const ...}": {
    "prefix": "s-const",
    "body": ["{@const ${1:name} = ${2:expression}}"],
    "description": "Svelte: define a template-local constant"
  },
  "svelte: {@attach ...} (in an element tag)": {
    "prefix": "s-attach",
    "body": ["{@attach ${1:attachment}}"],
    "description": "Svelte 5.29+: element attachment (reactive alternative to actions)"
  },

  "svelte: $host() custom-element dispatch": {
    "prefix": "s-host-dispatch",
    "body": [
      "<svelte:options customElement=\"${1:my-element}\" />",
      "",
      "<script>",
      "\tfunction ${2:dispatch}(type, detail) {",
      "\t\t$host().dispatchEvent(new CustomEvent(type, { detail }));",
      "\t}",
      "</script>"
    ],
    "description": "Svelte 5: $host() for custom elements (dispatch CustomEvent)"
  },
  "console.log shortcut": {
    "prefix": "clg",
    "body": [
      "console.log(${1})"
    ],
    "description": "add a script to your svelte file"
  },
  "Function (Arrow)": {
    "prefix": "af",
    "body": [
      "const ${1} = (${2}) => {",
      "  ${3}",
      "}",
      "${4}"
    ]
  },
  "Async Function (Arrow)": {
    "prefix": "afa",
    "body": [
